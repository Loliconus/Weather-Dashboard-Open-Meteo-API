# =============================================================
# ПУТЬ        : .gitignore
# ОБОЗНАЧЕНИЕ : WD.CONF.05
# НАИМЕНОВАНИЕ: Исключения Git
# ДОКУМЕНТ    : КС-СТО-1.04.СК
# ПРОГРАММА   : Weather Dashboard
# =============================================================

# -------------------------------------------------------------
# Раздел 1. Python
# -------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# -------------------------------------------------------------
# Раздел 2. Виртуальные окружения
# -------------------------------------------------------------
.venv/
venv/
env/
.env.local
.env.*.local

# Переменные среды (не коммитить реальные секреты)
.env
!.env.example

# -------------------------------------------------------------
# Раздел 3. Инструменты
# -------------------------------------------------------------
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.hypothesis/

# -------------------------------------------------------------
# Раздел 4. IDE
# -------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# -------------------------------------------------------------
# Раздел 5. Проектные артефакты (не коммитятся — генерируются)
# -------------------------------------------------------------
# РЕШЕНИЕ: docs/data/*.json и *.csv генерируются Actions,
# в репозитории хранятся только заглушки (fixtures).
# docs/data/