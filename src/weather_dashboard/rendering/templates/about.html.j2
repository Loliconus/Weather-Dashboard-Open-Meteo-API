  {# ══════════════════════════════════════════════════════
     PAGE HEADER
  ══════════════════════════════════════════════════════ #}
  <header class="page-header" role="banner">
    <div class="page-header__icon" aria-hidden="true">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none"
           stroke="rgba(255,255,255,.9)" stroke-width="1.8"
