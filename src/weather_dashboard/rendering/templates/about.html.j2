<!DOCTYPE html>
<html lang="ru" data-theme="auto">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description"
        content="Сведения об источниках данных, правовой оговорке и конфиденциальности Weather Dashboard" />
  <meta name="robots" content="noindex, follow" />

  {# CSP: нет внешних запросов из браузера — connect-src 'none' #}
  <meta http-equiv="Content-Security-Policy"
        content="default-src 'self';
                 style-src 'self' 'unsafe-inline';
                 script-src 'self' 'unsafe-inline';
                 img-src 'self' data:;
                 font-src 'self';
                 connect-src 'none';" />

  <title>Об источниках данных — Weather Dashboard</title>

  <style>
    /* ─── CSS Custom Properties ─────────────────────────────────────────── */
    :root {
      --color-bg:           #f8fafc;
      --color-surface:      #ffffff;
      --color-surface-alt:  #f1f5f9;
      --color-border:       #e2e8f0;
      --color-text:         #0f172a;
      --color-text-muted:   #64748b;
      --color-text-subtle:  #94a3b8;
      --color-primary:      #3b82f6;
      --color-primary-dark: #1d4ed8;
      --color-success:      #22c55e;
      --color-warning:      #f59e0b;
      --color-danger:       #ef4444;
      --color-info:         #06b6d4;

      --color-cc-badge-bg:  #dbeafe;
      --color-cc-badge-fg:  #1d4ed8;

      --radius-sm: 0.375rem;
      --radius-md: 0.75rem;
      --radius-lg: 1rem;
      --radius-xl: 1.5rem;

      --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / .05);
      --shadow-md: 0 4px 6px -1px rgb(0 0 0 / .1), 0 2px 4px -2px rgb(0 0 0 / .1);
      --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / .1), 0 4px 6px -4px rgb(0 0 0 / .1);

      --transition: 200ms cubic-bezier(.4,0,.2,1);
      --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                   "Helvetica Neue", Arial, sans-serif;
      --font-mono: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;

      --max-w: 900px;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --color-bg:           #0b1120;
        --color-surface:      #111827;
        --color-surface-alt:  #1e293b;
        --color-border:       #1e293b;
        --color-text:         #f1f5f9;
        --color-text-muted:   #94a3b8;
        --color-text-subtle:  #475569;
        --color-primary:      #60a5fa;
        --color-primary-dark: #93c5fd;

        --color-cc-badge-bg: #1e3a5f;
        --color-cc-badge-fg: #93c5fd;

        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / .4);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / .5);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / .5);
      }
    }

    /* ─── Reset ─────────────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

    body {
      font-family: var(--font-sans);
      background: var(--color-bg);
      color: var(--color-text);
      line-height: 1.6;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
    }

    a {
      color: var(--color-primary);
      text-decoration: none;
      transition: color var(--transition), text-decoration-color var(--transition);
    }
    a:hover,
    a:focus-visible {
      color: var(--color-primary-dark);
      text-decoration: underline;
    }
    a:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 2px;
      border-radius: 2px;
    }

    /* ─── Skip link ──────────────────────────────────────────────────────── */
    .skip-link {
      position: absolute;
      top: -40px;
      left: 0;
      background: var(--color-primary);
      color: #fff;
      padding: .5rem 1rem;
      border-radius: 0 0 var(--radius-sm) 0;
      font-weight: 600;
      z-index: 9999;
      transition: top var(--transition);
    }
    .skip-link:focus { top: 0; }

    /* ─── Nav ─────────────────────────────────────────────────────────────── */
    .site-nav {
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
      box-shadow: var(--shadow-sm);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .site-nav__inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: .75rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .site-nav__brand {
      display: flex;
      align-items: center;
      gap: .5rem;
      font-weight: 700;
      font-size: 1.05rem;
      color: var(--color-text);
      text-decoration: none;
    }
    .site-nav__brand:hover { color: var(--color-primary); text-decoration: none; }
    .site-nav__brand svg  { flex-shrink: 0; }

    .site-nav__links {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      list-style: none;
    }
    .site-nav__links a {
      font-size: .9rem;
      font-weight: 500;
      color: var(--color-text-muted);
    }
    .site-nav__links a:hover { color: var(--color-primary); }
    .site-nav__links a[aria-current="page"] {
      color: var(--color-primary);
      font-weight: 700;
    }

    /* ─── Page header ─────────────────────────────────────────────────────── */
    .page-header {
      background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%);
      color: #fff;
      padding: 3.5rem 1.5rem 3rem;
      text-align: center;
    }
    @media (prefers-color-scheme: dark) {
      .page-header { background: linear-gradient(135deg, #0f172a 0%, #020617 100%); }
    }
    .page-header__icon {
      width: 64px;
      height: 64px;
      background: rgba(255,255,255,.1);
      border-radius: var(--radius-xl);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.25rem;
      backdrop-filter: blur(8px);
    }
    .page-header__title {
      font-size: clamp(1.6rem, 4vw, 2.25rem);
      font-weight: 800;
      letter-spacing: -.02em;
      margin-bottom: .5rem;
    }
    .page-header__subtitle {
      font-size: 1rem;
      color: rgba(255,255,255,.7);
      max-width: 560px;
      margin: 0 auto;
    }

    /* ─── Main layout ─────────────────────────────────────────────────────── */
    main {
      flex: 1;
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 2.5rem 1.5rem 4rem;
      width: 100%;
    }

    /* ─── Section ─────────────────────────────────────────────────────────── */
    .section {
      margin-bottom: 2.5rem;
      opacity: 0;
      transform: translateY(16px);
      transition: opacity .45s ease, transform .45s ease;
    }
    .section.visible { opacity: 1; transform: translateY(0); }

    .section__heading {
      display: flex;
      align-items: center;
      gap: .6rem;
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--color-text);
      margin-bottom: 1.25rem;
      padding-bottom: .625rem;
      border-bottom: 2px solid var(--color-border);
    }
    .section__heading svg { flex-shrink: 0; color: var(--color-primary); }

    /* ─── Attribution cards ───────────────────────────────────────────────── */
    .attr-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 400px), 1fr));
    }

    .attr-card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: 1.25rem 1.5rem;
      box-shadow: var(--shadow-sm);
      transition: box-shadow var(--transition), border-color var(--transition);
      display: flex;
      flex-direction: column;
      gap: .75rem;
    }
    .attr-card:hover {
      box-shadow: var(--shadow-md);
      border-color: var(--color-primary);
    }

    .attr-card__header {
      display: flex;
      align-items: flex-start;
      gap: .875rem;
    }
    .attr-card__logo {
      width: 44px;
      height: 44px;
      border-radius: var(--radius-md);
      background: var(--color-surface-alt);
      border: 1px solid var(--color-border);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 1.5rem;
      line-height: 1;
    }
    .attr-card__meta  { flex: 1; min-width: 0; }
    .attr-card__name  {
      font-size: 1rem;
      font-weight: 700;
      color: var(--color-text);
      margin-bottom: .15rem;
    }
    .attr-card__role  {
      font-size: .8rem;
      color: var(--color-text-muted);
      text-transform: uppercase;
      letter-spacing: .04em;
      font-weight: 600;
    }

    .attr-card__body {
      font-size: .875rem;
      color: var(--color-text-muted);
      line-height: 1.65;
    }
    .attr-card__body p + p { margin-top: .4rem; }

    .attr-card__footer {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
      padding-top: .5rem;
      border-top: 1px solid var(--color-border);
    }

    /* ─── Badges ──────────────────────────────────────────────────────────── */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: .3rem;
      padding: .2rem .6rem;
      border-radius: 9999px;
      font-size: .75rem;
      font-weight: 600;
      white-space: nowrap;
    }
    .badge--cc   { background: var(--color-cc-badge-bg); color: var(--color-cc-badge-fg); }
    .badge--doi  { background: #d1fae5; color: #065f46; }
    .badge--link {
      background: var(--color-surface-alt);
      color: var(--color-text-muted);
      border: 1px solid var(--color-border);
    }
    @media (prefers-color-scheme: dark) {
      .badge--doi  { background: #064e3b; color: #6ee7b7; }
    }

    /* ─── Prose cards ─────────────────────────────────────────────────────── */
    .prose-card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: 1.5rem;
      box-shadow: var(--shadow-sm);
    }
    .prose-card + .prose-card { margin-top: 1rem; }

    .prose-card__icon-row {
      display: flex;
      align-items: center;
      gap: .6rem;
      margin-bottom: 1rem;
    }
    .prose-card__icon-row svg { flex-shrink: 0; }
    .prose-card__icon-row h3  {
      font-size: 1rem;
      font-weight: 700;
      color: var(--color-text);
    }

    .prose-card--warning { border-left: 4px solid var(--color-warning); }
    .prose-card--info    { border-left: 4px solid var(--color-info); }
    .prose-card--success { border-left: 4px solid var(--color-success); }

    .prose-card p {
      font-size: .875rem;
      color: var(--color-text-muted);
      line-height: 1.7;
    }
    .prose-card p + p { margin-top: .6rem; }

    /* ─── API table ───────────────────────────────────────────────────────── */
    .api-table-wrap {
      overflow-x: auto;
      border-radius: var(--radius-lg);
      border: 1px solid var(--color-border);
      box-shadow: var(--shadow-sm);
    }
    .api-table {
      width: 100%;
      border-collapse: collapse;
      font-size: .875rem;
      background: var(--color-surface);
    }
    .api-table thead { background: var(--color-surface-alt); }
    .api-table th {
      padding: .75rem 1rem;
      text-align: left;
      font-weight: 700;
      color: var(--color-text-muted);
      font-size: .75rem;
      text-transform: uppercase;
      letter-spacing: .06em;
      border-bottom: 1px solid var(--color-border);
    }
    .api-table td {
      padding: .75rem 1rem;
      color: var(--color-text);
      border-bottom: 1px solid var(--color-border);
      vertical-align: middle;
    }
    .api-table tbody tr:last-child td { border-bottom: none; }
    .api-table tbody tr:hover { background: var(--color-surface-alt); }
    .api-table code {
      font-family: var(--font-mono);
      font-size: .82rem;
      background: var(--color-surface-alt);
      border: 1px solid var(--color-border);
      padding: .1em .4em;
      border-radius: var(--radius-sm);
    }

    /* Индикатор статуса */
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: .35rem;
      font-size: .78rem;
      font-weight: 600;
      padding: .15rem .55rem;
      border-radius: 9999px;
    }
    .status-badge::before {
      content: "";
      display: block;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* Зелёный пульс — API активен при сборке */
    .status-badge--build {
      background: color-mix(in srgb, var(--color-success) 12%, transparent);
      color: #15803d;
    }
    .status-badge--build::before {
      background: var(--color-success);
      animation: pulse-dot 2s ease-in-out infinite;
      box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-success) 25%, transparent);
    }
    @media (prefers-color-scheme: dark) {
      .status-badge--build { color: #4ade80; }
    }

    /* Серый — не используется */
    .status-badge--unused {
      background: var(--color-surface-alt);
      color: var(--color-text-subtle);
    }
    .status-badge--unused::before { background: var(--color-text-subtle); }

    @keyframes pulse-dot {
      0%, 100% { box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-success) 25%, transparent); }
      50%       { box-shadow: 0 0 0 5px color-mix(in srgb, var(--color-success) 10%, transparent); }
    }

    /* ─── License box ─────────────────────────────────────────────────────── */
    .license-box {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: 1.25rem 1.5rem;
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      box-shadow: var(--shadow-sm);
    }
    .license-box__icon {
      font-size: 2rem;
      line-height: 1;
      flex-shrink: 0;
    }
    .license-box__body h4 {
      font-size: .95rem;
      font-weight: 700;
      margin-bottom: .35rem;
    }
    .license-box__body p {
      font-size: .85rem;
      color: var(--color-text-muted);
      line-height: 1.6;
    }

    /* ─── Footer ──────────────────────────────────────────────────────────── */
    .site-footer {
      background: var(--color-surface);
      border-top: 1px solid var(--color-border);
      padding: 1.75rem 1.5rem;
      margin-top: auto;
    }
    .site-footer__inner {
      max-width: var(--max-w);
      margin: 0 auto;
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
      justify-content: space-between;
    }
    .site-footer__left {
      display: flex;
      flex-direction: column;
      gap: .3rem;
    }
    .site-footer__attribution {
      font-size: .825rem;
      color: var(--color-text-muted);
      font-weight: 500;
    }
    .site-footer__attribution a { font-weight: 700; }
    .site-footer__meta {
      font-size: .775rem;
      color: var(--color-text-subtle);
    }
    .site-footer__right {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: .3rem;
    }
    .site-footer__version {
      font-size: .775rem;
      color: var(--color-text-subtle);
      font-family: var(--font-mono);
    }
    .site-footer__links {
      display: flex;
      gap: .875rem;
      font-size: .8rem;
    }

    /* ─── Utility ─────────────────────────────────────────────────────────── */
    .visually-hidden {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0,0,0,0);
      white-space: nowrap;
      border: 0;
    }

    @media (max-width: 640px) {
      .site-nav__links  { gap: 1rem; }
      .attr-grid        { grid-template-columns: 1fr; }
      .site-footer__inner { flex-direction: column; align-items: flex-start; }
      .site-footer__right { align-items: flex-start; }
    }
  </style>
</head>

<body>
  <a href="#main-content" class="skip-link">Перейти к содержимому</a>

  {# ══════════════════════════════════════════════════════
     NAV
  ══════════════════════════════════════════════════════ #}
  <nav class="site-nav" aria-label="Основная навигация">
    <div class="site-nav__inner">
      <a href="index.html" class="site-nav__brand"
         aria-label="Weather Dashboard — главная">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41
                   M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
