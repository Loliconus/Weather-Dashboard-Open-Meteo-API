# =============================================================
# ПУТЬ        : .editorconfig
# ОБОЗНАЧЕНИЕ : WD.CONF.04
# НАИМЕНОВАНИЕ: Единые настройки редактора
# ДОКУМЕНТ    : КС-СТО-1.04.СК
# ПРОГРАММА   : Weather Dashboard
# =============================================================

root = true

# -------------------------------------------------------------
# Раздел 1. Глобальные настройки
# -------------------------------------------------------------

[*]
charset                  = utf-8
end_of_line              = lf
indent_style             = space
indent_size              = 4
trim_trailing_whitespace = true
insert_final_newline     = true
max_line_length          = 88

# -------------------------------------------------------------
# Раздел 2. Специфичные для форматов
# -------------------------------------------------------------

[*.{js,ts,json,yaml,yml,css,html,md,j2}]
indent_size = 2

[*.{toml,ini,cfg}]
indent_size = 4

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
max_line_length          = off

[*.{bat,cmd}]
end_of_line = crlf